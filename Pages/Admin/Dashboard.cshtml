@page
@model TheWeebDenShop.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<main class="main-content">
    <div class="container py-5">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold"><i class="fas fa-shield-alt me-2 text-warning"></i>Admin Dashboard</h1>
                <p class="text-muted mb-0">Manage users, stores, and manga listings</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@successMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Analytics Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-users fa-2x text-primary mb-2"></i>
                        <h3 class="fw-bold mb-0">@Model.TotalUsers</h3>
                        <small class="text-muted">Total Users</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-store fa-2x text-success mb-2"></i>
                        <h3 class="fw-bold mb-0">@Model.TotalStores</h3>
                        <small class="text-muted">Active Stores</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-book fa-2x text-info mb-2"></i>
                        <h3 class="fw-bold mb-0">@Model.TotalListings</h3>
                        <small class="text-muted">Manga Listings</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card border-0 shadow-sm rounded-3 h-100">
                    <div class="card-body text-center">
                        <i class="fas fa-ban fa-2x text-danger mb-2"></i>
                        <h3 class="fw-bold mb-0">@Model.BannedListings</h3>
                        <small class="text-muted">Banned Listings</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Users Section -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-users me-2"></i>Users (@Model.Users.Count)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Store</th>
                                <th>Listings</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td>@user.FirstName @user.LastName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        @if (Model.UserRoles.TryGetValue(user.Id, out var roles))
                                        {
                                            @foreach (var role in roles)
                                            {
                                                <span class="badge @(role == "Admin" ? "bg-warning text-dark" : "bg-secondary")">@role</span>
                                            }
                                        }
                                    </td>
                                    <td>
                                        @if (Model.UserStores.TryGetValue(user.Id, out var store))
                                        {
                                            <a asp-page="/StoreView" asp-route-id="@store.Id" class="text-decoration-none">
                                                @store.Name
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @(Model.UserStores.TryGetValue(user.Id, out var s) 
                                            ? Model.StoreListingCounts.GetValueOrDefault(s.Id, 0).ToString() 
                                            : "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- All Manga Listings (user-created) -->
        <div class="card border-0 shadow-sm rounded-3 mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0"><i class="fas fa-book-open me-2"></i>User Manga Listings (@Model.AllUserListings.Count)</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.AllUserListings.Count == 0)
                {
                    <div class="text-center p-4 text-muted">No user-created listings yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Cover</th>
                                    <th>Title</th>
                                    <th>Store</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var manga in Model.AllUserListings)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(manga.Image))
                                            {
                                                <img src="~/@manga.Image" alt="@manga.Name" 
                                                     style="width: 40px; height: 55px; object-fit: cover;" class="rounded" />
                                            }
                                        </td>
                                        <td>@manga.Name<br/><small class="text-muted">by @manga.Author</small></td>
                                        <td>@(manga.Store?.Name ?? "—")</td>
                                        <td>@Helpers.ProductHtmlHelpers.FormatPrice(manga.Price)</td>
                                        <td><span class="badge @Helpers.ProductHtmlHelpers.GetStockBadgeClass(manga.Stock)">@manga.Stock</span></td>
                                        <td>
                                            @if (manga.IsBanned)
                                            {
                                                <span class="badge bg-danger">Banned</span>
                                            }
                                            else if (!manga.IsApproved)
                                            {
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!manga.IsBanned)
                                            {
                                                <form method="post" asp-page-handler="BanListing" class="d-inline">
                                                    <input type="hidden" name="listingId" value="@manga.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                            title="Ban this listing">
                                                        <i class="fas fa-ban"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form method="post" asp-page-handler="UnbanListing" class="d-inline">
                                                    <input type="hidden" name="listingId" value="@manga.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" 
                                                            title="Unban this listing">
                                                        <i class="fas fa-check"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</main>
