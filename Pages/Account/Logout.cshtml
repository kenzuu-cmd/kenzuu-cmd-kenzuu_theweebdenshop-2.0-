@page
@model TheWeebDenShop.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logged Out";
}

<main class="main-content">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="mb-4">
                    <i class="fas fa-hand-peace text-primary" style="font-size: 5rem;"></i>
                </div>
                <h2 class="fw-bold text-primary">You have been logged out</h2>
                <p class="lead text-muted mb-4">Thanks for visiting The Weeb Den! See you next time.</p>
                <a asp-page="/Index" class="btn btn-primary btn-lg">
                    <i class="fas fa-home me-2"></i>Return Home
                </a>
            </div>
        </div>
    </div>
</main>
