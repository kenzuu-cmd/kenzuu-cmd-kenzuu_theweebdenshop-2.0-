@page
@model TheWeebDenShop.Pages.Store.DashboardModel
@{
    ViewData["Title"] = "My Store Dashboard";
}

<main class="main-content">
    <div class="container py-5">
        <!-- Page header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold"><i class="fas fa-store me-2 text-primary"></i>My Store Dashboard</h1>
                <p class="text-muted mb-0">Manage your manga listings and store profile</p>
            </div>
            @if (Model.UserStore != null)
            {
                <a asp-page="/Store/AddManga" class="btn btn-success btn-lg">
                    <i class="fas fa-plus me-2"></i>Add New Manga
                </a>
            }
        </div>

        @if (TempData["SuccessMessage"] is string successMsg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@successMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMsg)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (Model.UserStore == null)
        {
            <!-- No store yet — prompt to create one -->
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="card shadow-sm border-0 rounded-4 text-center p-5">
                        <div class="mb-3"><i class="fas fa-store fa-4x text-muted"></i></div>
                        <h3 class="fw-bold">You don't have a store yet!</h3>
                        <p class="text-muted mb-4">Create your manga store to start listing and selling your collection.</p>
                        
                        <form method="post" asp-page-handler="CreateStore" enctype="multipart/form-data">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                            
                            <div class="mb-3 text-start">
                                <label asp-for="StoreInput.Name" class="form-label fw-semibold">Store Name *</label>
                                <input asp-for="StoreInput.Name" class="form-control form-control-lg" placeholder="e.g., Sakura Manga Shop" />
                                <span asp-validation-for="StoreInput.Name" class="text-danger small"></span>
                            </div>
                            <div class="mb-3 text-start">
                                <label asp-for="StoreInput.Description" class="form-label fw-semibold">Store Description</label>
                                <textarea asp-for="StoreInput.Description" class="form-control" rows="3" 
                                          placeholder="Tell buyers about your store and what kind of manga you sell..."></textarea>
                                <span asp-validation-for="StoreInput.Description" class="text-danger small"></span>
                            </div>
                            <div class="mb-4 text-start">
                                <label asp-for="StoreLogo" class="form-label fw-semibold">Store Logo (optional)</label>
                                <input asp-for="StoreLogo" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,.gif" />
                                <small class="text-muted">Max 5 MB. JPG, PNG, WebP, or GIF.</small>
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-rocket me-2"></i>Create My Store
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- Store profile card -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body d-flex align-items-center gap-4 p-4">
                    @if (!string.IsNullOrEmpty(Model.UserStore.LogoPath))
                    {
                        <img src="~/@Model.UserStore.LogoPath" alt="Store Logo" 
                             class="rounded-circle" style="width: 80px; height: 80px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white" 
                             style="width: 80px; height: 80px; font-size: 2rem;">
                            <i class="fas fa-store"></i>
                        </div>
                    }
                    <div class="flex-grow-1">
                        <h3 class="fw-bold mb-1">@Model.UserStore.Name</h3>
                        <p class="text-muted mb-0">@(Model.UserStore.Description ?? "No description yet.")</p>
                    </div>
                    <div>
                        <a asp-page="/StoreView" asp-route-id="@Model.UserStore.Id" class="btn btn-outline-primary me-2">
                            <i class="fas fa-eye me-1"></i>View Public Page
                        </a>
                    </div>
                </div>
            </div>

            <!-- Best practices tip -->
            <div class="alert alert-info border-0 rounded-3 mb-4" role="alert">
                <h6 class="fw-bold mb-1"><i class="fas fa-lightbulb me-1"></i>Tips for Great Listings</h6>
                <small>Use clear, high-quality cover photos. Write detailed descriptions including condition, edition, and any special features. Keep stock counts accurate to build buyer trust.</small>
            </div>

            <!-- Manga listings grid -->
            <h4 class="fw-bold mb-3">
                <i class="fas fa-book-open me-2"></i>Your Manga Listings 
                <span class="badge bg-secondary">@Model.StoreProducts.Count</span>
            </h4>

            @if (Model.StoreProducts.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No manga listed yet. Click "Add New Manga" to get started!</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var manga in Model.StoreProducts)
                    {
                        <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                            <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                                <!-- Status badges -->
                                <div class="position-relative">
                                    @if (manga.IsBanned)
                                    {
                                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">Banned</span>
                                    }
                                    else if (!manga.IsApproved)
                                    {
                                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Pending</span>
                                    }
                                    @if (!string.IsNullOrEmpty(manga.Image))
                                    {
                                        <img src="~/@manga.Image" class="card-img-top" alt="@manga.Name" 
                                             style="height: 220px; object-fit: cover;" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    }
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">@manga.Name</h6>
                                    <p class="text-muted small mb-1">by @manga.Author</p>
                                    <div class="mb-2">
                                        <span class="fw-bold text-primary">@Helpers.ProductHtmlHelpers.FormatPrice(manga.Price)</span>
                                        <span class="badge @Helpers.ProductHtmlHelpers.GetStockBadgeClass(manga.Stock) ms-2">
                                            @Helpers.ProductHtmlHelpers.GetStockText(manga.Stock)
                                        </span>
                                    </div>
                                    <div class="mt-auto d-flex gap-2">
                                        <a asp-page="/Store/EditManga" asp-route-id="@manga.Id" 
                                           class="btn btn-sm btn-outline-primary flex-fill">
                                            <i class="fas fa-edit me-1"></i>Edit
                                        </a>
                                        <form method="post" asp-page-handler="DeleteManga" class="flex-fill"
                                              onsubmit="return confirm('Are you sure you want to delete this manga?');">
                                            <input type="hidden" name="mangaId" value="@manga.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                <i class="fas fa-trash me-1"></i>Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</main>
