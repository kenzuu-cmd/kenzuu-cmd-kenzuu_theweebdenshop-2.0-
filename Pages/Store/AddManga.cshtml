@page
@model TheWeebDenShop.Pages.Store.AddMangaModel
@{
    ViewData["Title"] = "Add New Manga";
}

<main class="main-content">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-7">
                <div class="mb-3">
                    <a asp-page="/Store/Dashboard" class="text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i>Back to Dashboard
                    </a>
                </div>

                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="card-header text-white py-3 border-0" style="background: var(--color-success);">
                        <h3 class="mb-0 fw-bold"><i class="fas fa-plus-circle me-2"></i>Add New Manga</h3>
                    </div>
                    <div class="card-body p-4">
                        <form method="post" enctype="multipart/form-data">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                            <!-- Title -->
                            <div class="mb-3">
                                <label asp-for="Input.Title" class="form-label fw-semibold">Manga Title *</label>
                                <input asp-for="Input.Title" class="form-control form-control-lg" 
                                       placeholder="e.g., One Piece Vol. 1" />
                                <span asp-validation-for="Input.Title" class="text-danger small"></span>
                            </div>

                            <!-- Author -->
                            <div class="mb-3">
                                <label asp-for="Input.Author" class="form-label fw-semibold">Author *</label>
                                <input asp-for="Input.Author" class="form-control" placeholder="e.g., Eiichiro Oda" />
                                <span asp-validation-for="Input.Author" class="text-danger small"></span>
                            </div>

                            <!-- Description -->
                            <div class="mb-3">
                                <label asp-for="Input.Description" class="form-label fw-semibold">Description</label>
                                <textarea asp-for="Input.Description" class="form-control" rows="4"
                                          placeholder="Describe the manga, its condition, edition details..."></textarea>
                                <span asp-validation-for="Input.Description" class="text-danger small"></span>
                            </div>

                            <!-- Genre and Volumes row -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Genre" class="form-label fw-semibold">Genre *</label>
                                    <select asp-for="Input.Genre" class="form-select">
                                        <option value="">Select Genre</option>
                                        <option value="Action">Action</option>
                                        <option value="Adventure">Adventure</option>
                                        <option value="Comedy">Comedy</option>
                                        <option value="Drama">Drama</option>
                                        <option value="Fantasy">Fantasy</option>
                                        <option value="Horror">Horror</option>
                                        <option value="Mystery">Mystery</option>
                                        <option value="Romance">Romance</option>
                                        <option value="Sci-Fi">Sci-Fi</option>
                                        <option value="Slice of Life">Slice of Life</option>
                                        <option value="Sports">Sports</option>
                                        <option value="Thriller">Thriller</option>
                                    </select>
                                    <span asp-validation-for="Input.Genre" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Volumes" class="form-label fw-semibold">Volumes</label>
                                    <input asp-for="Input.Volumes" class="form-control" type="number" min="1" max="1000" />
                                    <span asp-validation-for="Input.Volumes" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Price and Stock row -->
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Price" class="form-label fw-semibold">Price (₱) *</label>
                                    <div class="input-group">
                                        <span class="input-group-text">₱</span>
                                        <input asp-for="Input.Price" class="form-control" type="number" 
                                               step="0.01" min="0.01" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="Input.Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Input.Stock" class="form-label fw-semibold">Stock *</label>
                                    <input asp-for="Input.Stock" class="form-control" type="number" min="0" max="99999" />
                                    <span asp-validation-for="Input.Stock" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Cover Image Upload -->
                            <div class="mb-4">
                                <label asp-for="Input.CoverImage" class="form-label fw-semibold">Cover Image *</label>
                                <input asp-for="Input.CoverImage" class="form-control" type="file" 
                                       accept=".jpg,.jpeg,.png,.webp,.gif" id="coverImageInput" 
                                       onchange="previewImage(this)" />
                                <small class="text-muted">Max 5 MB. JPG, PNG, WebP, or GIF. Use a clear, high-quality cover photo.</small>
                                <span asp-validation-for="Input.CoverImage" class="text-danger small d-block"></span>
                                <!-- Preview -->
                                <div id="imagePreview" class="mt-2" style="display:none;">
                                    <img id="previewImg" src="#" alt="Preview" class="rounded shadow-sm" 
                                         style="max-height: 200px; object-fit: cover;" />
                                </div>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="fas fa-plus-circle me-2"></i>Add Manga
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
<script>
    function previewImage(input) {
        const preview = document.getElementById('imagePreview');
        const img = document.getElementById('previewImg');
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function(e) {
                img.src = e.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(input.files[0]);
        } else {
            preview.style.display = 'none';
        }
    }
</script>
}
