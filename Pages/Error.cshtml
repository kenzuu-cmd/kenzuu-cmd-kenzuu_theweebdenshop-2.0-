@page
@model TheWeebDenShop.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<main class="main-content">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 text-center">
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle text-warning" style="font-size: 5rem;"></i>
                </div>
                <h1 class="display-4 fw-bold text-primary">Oops!</h1>
                <p class="lead text-muted mb-4">Something went wrong while processing your request.</p>

                @if (!string.IsNullOrEmpty(Model.RequestId))
                {
                    <p class="text-muted"><strong>Request ID:</strong> @Model.RequestId</p>
                }

                <a asp-page="/Index" class="btn btn-primary btn-lg mt-3">
                    <i class="fas fa-home me-2"></i>Return Home
                </a>
            </div>
        </div>
    </div>
</main>
