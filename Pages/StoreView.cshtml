@page "{id}"
@model TheWeebDenShop.Pages.StoreViewModel
@{
    ViewData["Title"] = Model.Store?.Name ?? "Store";
}

<main class="main-content">
    <div class="container py-5">
        @if (Model.Store == null)
        {
            <div class="text-center py-5">
                <i class="fas fa-store-slash fa-4x text-muted mb-3"></i>
                <h3 class="fw-bold">Store not found</h3>
                <p class="text-muted">This store doesn't exist or has been removed.</p>
                <a asp-page="/Products" class="btn btn-primary">
                    <i class="fas fa-book me-1"></i>Browse Products
                </a>
            </div>
        }
        else
        {
            <!-- Store banner / header -->
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.Store.BannerPath))
                {
                    <img src="~/@Model.Store.BannerPath" alt="Store banner" class="card-img-top" 
                         style="height: 200px; object-fit: cover;" />
                }
                else
                {
                    <div style="height: 120px; background: var(--color-primary);"></div>
                }
                <div class="card-body d-flex align-items-center gap-4 p-4">
                    @if (!string.IsNullOrEmpty(Model.Store.LogoPath))
                    {
                        <img src="~/@Model.Store.LogoPath" alt="@Model.Store.Name logo" 
                             class="rounded-circle shadow" 
                             style="width: 80px; height: 80px; object-fit: cover; margin-top: -50px; border: 4px solid white;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white shadow" 
                             style="width: 80px; height: 80px; font-size: 2rem; margin-top: -50px; border: 4px solid white;">
                            <i class="fas fa-store"></i>
                        </div>
                    }
                    <div>
                        <h2 class="fw-bold mb-1">@Model.Store.Name</h2>
                        <p class="text-muted mb-0">
                            @(string.IsNullOrEmpty(Model.Store.Description) ? "A manga store on The Weeb Den" : Model.Store.Description)
                        </p>
                        <small class="text-muted">
                            <i class="fas fa-book me-1"></i>@Model.StoreProducts.Count listings
                            &middot;
                            <i class="fas fa-calendar me-1"></i>Joined @Model.Store.CreatedAt.ToString("MMM yyyy")
                        </small>
                    </div>
                </div>
            </div>

            <!-- Product listings -->
            <h4 class="fw-bold mb-3"><i class="fas fa-book-open me-2"></i>Manga for Sale</h4>

            @if (Model.StoreProducts.Count == 0)
            {
                <div class="text-center py-5">
                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                    <p class="text-muted">This store hasn't listed any manga yet.</p>
                </div>
            }
            else
            {
                <div class="row">
                    @foreach (var manga in Model.StoreProducts)
                    {
                        <div class="col-sm-6 col-md-4 col-lg-3 mb-4">
                            <div class="card product-card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                                <div class="position-relative">
                                    @if (manga.Stock < 10 && manga.Stock > 0)
                                    {
                                        <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">Low Stock</span>
                                    }
                                    else if (manga.Stock == 0)
                                    {
                                        <span class="badge bg-danger position-absolute top-0 end-0 m-2">Out of Stock</span>
                                    }
                                    @if (!string.IsNullOrEmpty(manga.Image))
                                    {
                                        <img src="~/@manga.Image" class="card-img-top" alt="@manga.Name" 
                                             style="height: 240px; object-fit: cover;" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 240px;">
                                            <i class="fas fa-image fa-3x text-muted"></i>
                                        </div>
                                    }
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold">@manga.Name</h5>
                                    <p class="text-muted small mb-1"><i class="fas fa-user-edit me-1"></i>@manga.Author</p>
                                    <div class="mb-2">
                                        <span class="fw-bold text-primary fs-5">@Helpers.ProductHtmlHelpers.FormatPrice(manga.Price)</span>
                                        <span class="badge bg-secondary ms-1">@manga.Genre</span>
                                    </div>
                                    <p class="card-text text-muted small mb-3">@manga.Short</p>
                                    <div class="btn-group mt-auto">
                                        <a asp-page="/ProductDetail" asp-route-id="@manga.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-info-circle me-1"></i>Details
                                        </a>
                                        @if (manga.Stock > 0)
                                        {
                                            <form method="post" asp-page-handler="AddToCart" class="d-inline">
                                                <input type="hidden" name="productId" value="@manga.Id" />
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="fas fa-cart-plus me-1"></i>Add to Cart
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-secondary" disabled>Out of Stock</button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</main>
