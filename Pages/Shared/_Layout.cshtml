@* =========================================================================
   _Layout.cshtml — Shared layout for all pages.
   Extracted from the repeated <head>, <nav>, and <footer> in original HTML.
   All static asset paths use ~/ for ASP.NET static file resolution.
   Navigation uses asp-page tag helpers for maintainable routing.
   ========================================================================= *@
@inject TheWeebDenShop.Services.ICartService CartService
@inject Microsoft.AspNetCore.Identity.SignInManager<TheWeebDenShop.Models.ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<TheWeebDenShop.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — The Weeb Den</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Discover authentic Japanese manga, light novels, and collectibles at The Weeb Den. Your ultimate otaku paradise with rare editions and exclusive imports.")" />
    <meta name="keywords" content="manga, anime, light novels, Japanese books, otaku, collectibles" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <!-- Custom CSS — references moved to wwwroot -->
    <link rel="stylesheet" href="~/css/common.css" />
    <link rel="stylesheet" href="~/css/theme.css" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/images/weebdenfavicon.ico" />
    <link rel="shortcut icon" type="image/x-icon" href="~/images/weebdenfavicon.ico" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navigation — converted from repeated HTML to shared layout with asp-page tag helpers -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                <img src="~/images/weebden-logo.png" alt="The Weeb Den Logo" height="40" class="me-2 rounded" />
                <span class="fw-bold">The Weeb Den</span>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Index">
                            <i class="fas fa-home me-1" aria-hidden="true"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Products">
                            <i class="fas fa-book me-1" aria-hidden="true"></i>Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/About">
                            <i class="fas fa-info-circle me-1" aria-hidden="true"></i>About
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Contact">
                            <i class="fas fa-envelope me-1" aria-hidden="true"></i>Contact
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-page="/Cart" aria-label="Shopping cart">
                            <i class="fas fa-shopping-cart me-1" aria-hidden="true"></i>Cart
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                  id="cart-badge" aria-label="items in cart">@CartService.GetItemCount()</span>
                        </a>
                    </li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle me-1"></i>@(UserManager.GetUserAsync(User).Result?.FirstName ?? User.Identity?.Name)
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><span class="dropdown-item-text text-muted"><i class="fas fa-shield-alt me-1"></i>Admin</span></li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <form method="post" asp-page="/Account/Logout">
                                        <button type="submit" class="dropdown-item">
                                            <i class="fas fa-sign-out-alt me-1"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Account/Register">
                                <i class="fas fa-user-plus me-1"></i>Register
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- Footer — shared across all pages -->
    <footer class="py-4 bg-dark text-light">
        <div class="container d-flex justify-content-between align-items-center flex-wrap">
            <small>&copy; @DateTime.Now.Year The Weeb Den. All rights reserved.</small>
            <div>
                <a asp-page="/Privacy" class="text-light me-3 text-decoration-none">
                    <i class="fas fa-shield-alt me-1" aria-hidden="true"></i>Privacy
                </a>
                <a asp-page="/Terms" class="text-light text-decoration-none">
                    <i class="fas fa-file-contract me-1" aria-hidden="true"></i>Terms of Service
                </a>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Site JavaScript — shared site functionality -->
    <script src="~/js/site.js"></script>

    @if (TempData["Message"] is string message)
    {
        <div id="tempdata-message" data-message="@message" data-type="success" style="display:none;"></div>
    }
    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div id="tempdata-message" data-message="@successMsg" data-type="success" style="display:none;"></div>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
