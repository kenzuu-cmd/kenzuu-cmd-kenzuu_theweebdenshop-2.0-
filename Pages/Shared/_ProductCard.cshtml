@model Product

<div class="col-sm-6 col-md-4 col-lg-3 mb-4">
    <div class="card product-card h-100 border-0 shadow-sm">
        <div class="position-relative overflow-hidden">
            @if (Model.Stock == 0)
            {
                <span class="badge bg-danger position-absolute top-0 end-0 m-2" style="z-index:2;">Out of Stock</span>
            }
            else if (Model.Stock < 10)
            {
                <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2" style="z-index:2;">Low Stock</span>
            }
            @{
                var imgSrc = Model.Image.StartsWith("images/")
                    ? $"~/{Model.Image}"
                    : $"~/images/{System.IO.Path.GetFileName(Model.Image)}";
            }
            <img src="@imgSrc" class="card-img-top" alt="@Model.Name" loading="lazy" />
        </div>
        <div class="card-body d-flex flex-column">
            <h5 class="card-title text-truncate" title="@Model.Name">@Model.Name</h5>
            <p class="author-info mb-2 small text-muted">
                <i class="fas fa-user-edit me-1"></i>@Model.Author
            </p>
            <div class="rating mb-2">
                @ProductHtmlHelpers.GenerateStars(Html, Model.Rating)
                <small class="text-muted ms-1">(@Model.Rating)</small>
            </div>
            <div class="price-section mb-2 d-flex align-items-baseline gap-2">
                <span class="price fw-bold">@ProductHtmlHelpers.FormatPrice(Model.Price)</span>
                <span class="genre-badge">@Model.Genre</span>
            </div>
            <p class="card-text text-muted small mb-3 flex-grow-1">@Model.Short</p>
            <div class="btn-group mt-auto gap-1">
                <a asp-page="/ProductDetail" asp-route-id="@Model.Id" class="btn btn-sm btn-details">
                    <i class="fas fa-info-circle me-1"></i>Details
                </a>
                @if (Model.Stock > 0)
                {
                    <form method="post" asp-page="/Products" asp-page-handler="AddToCart" class="d-inline">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm btn-add">
                            <i class="fas fa-cart-plus me-1"></i>Add
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-sm btn-add" disabled>
                        <i class="fas fa-ban me-1"></i>Sold Out
                    </button>
                }
            </div>
        </div>
    </div>
</div>
