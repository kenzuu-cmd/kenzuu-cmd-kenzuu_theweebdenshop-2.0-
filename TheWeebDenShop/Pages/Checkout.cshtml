@page
@model TheWeebDenShop.Pages.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<main class="main-content">
    <div class="container py-4">
        <!-- Checkout Header -->
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold text-primary mb-3">
                <i class="fas fa-lock me-2"></i>Secure Checkout
            </h1>
            <p class="lead text-muted">
                Complete your order for authentic manga and Japanese collectibles.
            </p>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-7">
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle me-2"></i>@Model.SuccessMessage
                    </div>
                }

                <div class="card shadow-lg border-0 rounded-3 mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h4 class="mb-0"><i class="fas fa-shipping-fast me-2"></i>Order Information</h4>
                    </div>
                    <div class="card-body p-4">
                        <form method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <h5 class="mb-4 text-primary border-bottom pb-2">
                                <i class="fas fa-user me-2"></i>Shipping Information
                            </h5>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="CheckoutForm.FirstName" class="form-label"></label>
                                    <input asp-for="CheckoutForm.FirstName" class="form-control" placeholder="Enter first name" />
                                    <span asp-validation-for="CheckoutForm.FirstName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CheckoutForm.LastName" class="form-label"></label>
                                    <input asp-for="CheckoutForm.LastName" class="form-control" placeholder="Enter last name" />
                                    <span asp-validation-for="CheckoutForm.LastName" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="CheckoutForm.Email" class="form-label"></label>
                                    <input asp-for="CheckoutForm.Email" class="form-control" placeholder="your.email@example.com" />
                                    <span asp-validation-for="CheckoutForm.Email" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="CheckoutForm.Address" class="form-label"></label>
                                    <input asp-for="CheckoutForm.Address" class="form-control" placeholder="123 Main Street" />
                                    <span asp-validation-for="CheckoutForm.Address" class="text-danger"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CheckoutForm.City" class="form-label"></label>
                                    <input asp-for="CheckoutForm.City" class="form-control" placeholder="Enter city" />
                                    <span asp-validation-for="CheckoutForm.City" class="text-danger"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="CheckoutForm.State" class="form-label"></label>
                                    <input asp-for="CheckoutForm.State" class="form-control" placeholder="State" />
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="CheckoutForm.ZipCode" class="form-label"></label>
                                    <input asp-for="CheckoutForm.ZipCode" class="form-control" placeholder="12345" />
                                    <span asp-validation-for="CheckoutForm.ZipCode" class="text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="CheckoutForm.Country" class="form-label"></label>
                                    <select asp-for="CheckoutForm.Country" class="form-select">
                                        <option value="">Select Country</option>
                                        <option value="PH" selected>Philippines</option>
                                        <option value="US">United States</option>
                                        <option value="CA">Canada</option>
                                        <option value="UK">United Kingdom</option>
                                        <option value="JP">Japan</option>
                                        <option value="AU">Australia</option>
                                        <option value="SG">Singapore</option>
                                        <option value="MY">Malaysia</option>
                                        <option value="other">Other</option>
                                    </select>
                                    <span asp-validation-for="CheckoutForm.Country" class="text-danger"></span>
                                </div>
                            </div>

                            <hr class="my-4" />

                            <h5 class="mb-4 text-primary border-bottom pb-2">
                                <i class="fas fa-credit-card me-2"></i>Payment Method
                            </h5>
                            <div class="alert alert-info border-info">
                                <i class="fas fa-info-circle me-2"></i><strong>Demo Mode:</strong>
                                This is a demonstration checkout. No real payments are processed.
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-12">
                                    <div class="form-check mb-3 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="CheckoutForm.PaymentMethod" value="GCash" id="gcash" />
                                        <label class="form-check-label fw-bold" for="gcash">
                                            <i class="fas fa-mobile-alt me-2 text-primary"></i>GCash (Philippines)
                                        </label>
                                        <small class="d-block text-muted mt-1">Fast and secure mobile wallet payment</small>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-check mb-3 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="CheckoutForm.PaymentMethod" value="PayPal" id="paypal" />
                                        <label class="form-check-label fw-bold" for="paypal">
                                            <i class="fab fa-paypal me-2 text-primary"></i>PayPal
                                        </label>
                                        <small class="d-block text-muted mt-1">Pay with your PayPal account</small>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-check mb-3 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="CheckoutForm.PaymentMethod" value="CreditCard" id="creditCard" />
                                        <label class="form-check-label fw-bold" for="creditCard">
                                            <i class="fas fa-credit-card me-2 text-primary"></i>Credit/Debit Card
                                        </label>
                                        <small class="d-block text-muted mt-1">Visa, Mastercard, American Express</small>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-check mb-3 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="CheckoutForm.PaymentMethod" value="BankTransfer" id="bankTransfer" />
                                        <label class="form-check-label fw-bold" for="bankTransfer">
                                            <i class="fas fa-university me-2 text-primary"></i>Bank Transfer
                                        </label>
                                        <small class="d-block text-muted mt-1">Direct bank transfer (Instructions sent via email)</small>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-check mb-3 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="CheckoutForm.PaymentMethod" value="COD" id="cod" />
                                        <label class="form-check-label fw-bold" for="cod">
                                            <i class="fas fa-money-bill-wave me-2 text-primary"></i>Cash on Delivery
                                        </label>
                                        <small class="d-block text-muted mt-1">Pay when you receive your order</small>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid">
                                <button class="btn btn-success btn-lg text-white" type="submit">
                                    <i class="fas fa-check-circle me-2"></i>Complete Order
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Order Summary Sidebar -->
            <div class="col-lg-5">
                <div class="card shadow-lg border-0 rounded-3 sticky-summary">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            @foreach (var item in Model.CartItems)
                            {
                                <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                    <div class="d-flex align-items-center">
                                        <img src="~/images/@System.IO.Path.GetFileName(item.Image)" alt="@item.Name"
                                             class="rounded me-3" style="width: 60px; height: 80px; object-fit: cover;" />
                                        <div>
                                            <h6 class="mb-0">@item.Name</h6>
                                            <small class="text-muted">Qty: @item.Quantity &times; @ProductHtmlHelpers.FormatPrice(item.Price)</small>
                                        </div>
                                    </div>
                                    <strong>@ProductHtmlHelpers.FormatPrice(item.Subtotal)</strong>
                                </div>
                            }
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-2">
                            <span>Subtotal:</span>
                            <strong>@ProductHtmlHelpers.FormatPrice(Model.Subtotal)</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Tax (8%):</span>
                            <strong>@ProductHtmlHelpers.FormatPrice(Model.Tax)</strong>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between">
                            <span class="h5">Total:</span>
                            <strong class="h5 text-primary">@ProductHtmlHelpers.FormatPrice(Model.Total)</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
