@page
@model TheWeebDenShop.Pages.AboutModel
@{
    ViewData["Title"] = "About";
    ViewData["Description"] = "Learn about The Weeb Den — your trusted otaku paradise for authentic Japanese manga, light novels, and collectibles.";
}

<!-- Hero Section -->
<section class="about-hero py-5">
    <div class="container py-5 mt-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">About The Weeb Den</h1>
                <p class="lead mb-4">
                    Your trusted otaku paradise for authentic Japanese manga, light novels, and collectibles since 2025.
                </p>
                <p class="text-muted">
                    We're passionate fans bringing the best of Japanese pop culture directly to your doorstep.
                </p>
            </div>
            <div class="col-lg-6">
                <div class="about-hero-visual bg-primary-subtle rounded-4 p-5 text-center">
                    <img src="~/images/weebden-logo.png" alt="The Weeb Den Logo"
                         class="mb-3 d-block mx-auto" style="height: 120px; width: auto; object-fit: contain" />
                    <h3 class="fw-bold text-primary">16+ Products</h3>
                    <p class="text-muted mb-0">Curated with care for true fans</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Story Section -->
<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="text-center mb-5">
                    <h2 class="fw-bold mb-3">Our Story</h2>
                    <div class="divider-primary"></div>
                </div>
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-4 p-md-5">
                        <p class="lead mb-4">
                            The Weeb Den was founded by passionate anime and manga enthusiasts who wanted to bring
                            authentic Japanese otaku culture to fans worldwide.
                        </p>
                        <p class="mb-4">
                            We work directly with Japanese publishers and distributors to ensure every product in our
                            collection is genuine and of the highest quality. From rare doujinshi to limited edition
                            figures, we're your gateway to Japan's vibrant pop culture.
                        </p>
                        <p class="mb-0 text-muted fst-italic">
                            "Every product tells a story. We make sure it's authentic."
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us Section -->
<section class="py-5">
    <div class="container py-4">
        <div class="text-center mb-5">
            <h2 class="fw-bold mb-3">Why Choose The Weeb Den?</h2>
            <div class="divider-primary"></div>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 hover-lift">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle icon-lg">
                            <i class="fas fa-certificate fa-2x text-primary"></i>
                        </div>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Authentic Products</h5>
                    <p class="card-text text-muted">
                        All our manga and merchandise are officially licensed and imported directly from Japan.
                    </p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 hover-lift">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle icon-lg">
                            <i class="fas fa-star fa-2x text-primary"></i>
                        </div>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Expert Curation</h5>
                    <p class="card-text text-muted">
                        Our team of anime experts carefully selects each item to ensure quality and authenticity.
                    </p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 hover-lift">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle icon-lg">
                            <i class="fas fa-shipping-fast fa-2x text-primary"></i>
                        </div>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Fast Shipping</h5>
                    <p class="card-text text-muted">
                        Quick and secure worldwide shipping with tracking on all orders.
                    </p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 hover-lift">
                    <div class="mb-3">
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary-subtle icon-lg">
                            <i class="fas fa-box-open fa-2x text-primary"></i>
                        </div>
                    </div>
                    <h5 class="card-title fw-bold mb-3">Customer Support</h5>
                    <p class="card-text text-muted">
                        Dedicated support team to help with any questions about our products.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Our Mission Section -->
<section class="py-5 bg-light">
    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="text-center mb-5">
                    <h2 class="fw-bold mb-3">Our Mission</h2>
                    <div class="divider-primary"></div>
                </div>
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                            <div class="d-flex align-items-start">
                                <div class="flex-shrink-0 me-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white icon-md">
                                        <i class="fas fa-globe fa-lg"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="fw-bold mb-2">Global Community</h5>
                                    <p class="text-muted mb-0">
                                        Building a worldwide community of manga enthusiasts who share the same passion for Japanese culture and storytelling.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                            <div class="d-flex align-items-start">
                                <div class="flex-shrink-0 me-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white icon-md">
                                        <i class="fas fa-book-open fa-lg"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="fw-bold mb-2">Quality First</h5>
                                    <p class="text-muted mb-0">
                                        Every product goes through strict quality checks to ensure you receive only the best condition items for your collection.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                            <div class="d-flex align-items-start">
                                <div class="flex-shrink-0 me-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white icon-md">
                                        <i class="fas fa-handshake fa-lg"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="fw-bold mb-2">Trust &amp; Transparency</h5>
                                    <p class="text-muted mb-0">
                                        We maintain transparent business practices and build lasting relationships with our customers through honesty and reliability.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm rounded-4 h-100 p-4">
                            <div class="d-flex align-items-start">
                                <div class="flex-shrink-0 me-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white icon-md">
                                        <i class="fas fa-leaf fa-lg"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="fw-bold mb-2">Sustainable Practices</h5>
                                    <p class="text-muted mb-0">
                                        We use eco-friendly packaging materials and partner with publishers who practice responsible printing methods.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5">
    <div class="container py-4">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden bg-gradient-accent">
            <div class="card-body text-center text-white p-5">
                <h2 class="fw-bold mb-3">Ready to Start Your Collection?</h2>
                <p class="lead mb-4">Explore our curated selection of manga and light novels</p>
                <a asp-page="/Products" class="btn btn-light btn-lg px-5 py-3 fw-bold">
                    <i class="fas fa-book me-2"></i>Browse Products
                </a>
            </div>
        </div>
    </div>
</section>
