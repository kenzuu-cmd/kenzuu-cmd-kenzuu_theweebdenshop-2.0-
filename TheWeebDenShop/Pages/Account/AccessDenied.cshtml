@page
@model TheWeebDenShop.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}

<main class="main-content">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="mb-4">
                    <i class="fas fa-ban text-danger" style="font-size: 5rem;"></i>
                </div>
                <h2 class="fw-bold text-danger">Access Denied</h2>
                <p class="lead text-muted mb-4">You do not have permission to access this page.</p>
                <a asp-page="/Index" class="btn btn-primary btn-lg">
                    <i class="fas fa-home me-2"></i>Return Home
                </a>
            </div>
        </div>
    </div>
</main>
